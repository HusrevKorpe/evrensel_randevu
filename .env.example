# ------------------------------------------------------------
# Bu dosya bir ŞABLONDUR. Gerçek anahtarları buraya YAZMA.
# Kopyala:  cp .env.example .env.local   ve .env.local'i doldur.
# .env.local git'e gitmez (gizli kalır).
# ------------------------------------------------------------

# --- Supabase (Faz 1) ---
# supabase.com > Proje > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Sadece sunucu tarafında kullanılır, ASLA public olmasın:
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend / E-posta (Faz 5) ---
# resend.com > API Keys. Boşsa e-postalar sessizce atlanır (site yine çalışır).
RESEND_API_KEY=
# Gönderen adres. Kendi alan adını Resend'te doğruladıktan sonra doldur.
# Boşsa test adresi kullanılır: "Berber Randevu <onboarding@resend.dev>"
# (test adresi yalnızca kendi Resend hesabının e-postasına gönderir).
RESEND_FROM_EMAIL=
# Dükkan SAHİBİNİN e-postası (Faz 7): her yeni randevu talebinin kopyası
# buraya düşer; bildirim adresi tanımsız berberlerin talepleri de buraya gelir.
# Boşsa lib/site.ts'teki siteConfig.email kullanılır.
# (Berber bazlı adresler panelden yönetilir: /admin/ayarlar/berberler)
ADMIN_EMAIL=

# --- Bekleyen randevu cron'u (Faz 7) ---
# Cron, yanıtlanmamış (pending) randevuları her sabah BERBERE hatırlatır.
# Vercel Cron, CRON_SECRET tanımlıysa isteğe otomatik Bearer başlığı ekler;
# rastgele uzun bir değer üret (örn. `openssl rand -hex 32`).
CRON_SECRET=

# Maildeki tek-tık onay/red linklerinin imza anahtarı (İSTEĞE BAĞLI).
# Boşsa SUPABASE_SERVICE_ROLE_KEY'den türetilir — ekstra kurulum gerekmez.
APPROVAL_LINK_SECRET=

# --- Web Push bildirimleri (Faz 8) ---
# VAPID anahtar çifti üret:  npx web-push generate-vapid-keys
# PUBLIC istemciye gider (NEXT_PUBLIC_), PRIVATE yalnız sunucuda kalır.
# İkisi de boşsa push sessizce atlanır (e-posta gibi) → site yine çalışır.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Push servislerine kendini tanıtan iletişim (mailto:... veya https://...).
# Boşsa lib/site.ts'teki siteConfig.email kullanılır.
VAPID_SUBJECT=

# --- Genel ---
# Sitenin canlı adresi (deploy sonrası)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
